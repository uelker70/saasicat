{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "lib": ["ES2023", "DOM"],
        "types": ["vite/client"],
        "skipLibCheck": true,
        "jsx": "preserve",
        "esModuleInterop": true,
        "isolatedModules": true,
        "noEmit": true,
        "useDefineForClassFields": true
    },
    "include": ["src"]
}
