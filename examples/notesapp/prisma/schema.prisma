// NotesApp example — Prisma schema.
//
// App-owned tables (Tenant, User, Note) plus the full V3 platform surface
// from the canonical @saasicat/spec prisma-fragments:
//   01 (Subscription + payment method + checkout offer)
//   02 (PromoCode + redemption + validation log)
//   03 (Plan + PlanVersion)
//   04 (AuditLog)
//   05 (Bundle versioning)
//   06 (catalog entries + marketing)
//   07 (Promotion)
//   08 (SubscriptionContract + ContractLineItem)
//   10 (SuperAdmin + MFA)
// The platform blocks below are verbatim copies — regenerate them with:
//   pnpm exec saas-platform schema apply --fragments=01,02,03,04,05,06,07,08,10
// PostgreSQL constraints the Prisma DSL cannot express live in
// prisma/constraints.sql (applied by docker-entrypoint.sh after db push).

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// App tables — everything below is ordinary application modeling.
// -----------------------------------------------------------------------------

model Tenant {
    id        String   @id @default(uuid())
    slug      String   @unique
    name      String
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    users User[]
    notes Note[]

    subscription          Subscription?
    promoCodeRedemptions  PromoCodeRedemption[]
    subscriptionContracts SubscriptionContract[]

    @@map("tenants")
}

model User {
    id        String   @id @default(uuid())
    tenantId  String
    email     String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

    @@index([tenantId])
    @@map("users")
}

model Note {
    id        String   @id @default(uuid())
    tenantId  String
    title     String
    body      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

    @@index([tenantId, createdAt])
    @@map("notes")
}

// =============================================================================
// SaaS-Platform Prisma fragment: audit log
// =============================================================================
//
// REFERENCE SNIPPET — see 01-subscription.prisma for conventions.
//
// Generic audit log for tenant- and admin-side actions. Consumers
// can share the log or keep their own parallel logs — the
// `@saasicat/nest` package writes into this schema.
//
// `action` must follow SCREAMING_SNAKE_CASE (see
// `schemas/audit-event.schema.json` action pattern). Consumer-specific
// actions are allowed; platform actions are cataloged in the `AuditActionDef`
// list of the manifest contributions.

model AuditLog {
    id        String  @id @default(uuid())
    tenantId  String? // null for platform-global actions (plan publish etc.)
    userId    String? // actor — null for system cron or pre-auth actions
    entity    String // e.g. "Subscription", "PromoCode", "PlanVersion"
    entityId  String
    action    String // SCREAMING_SNAKE_CASE; e.g. "PROMO_CODE_REDEEM"
    changes   Json? // { field: { old: …, new: … } }
    // Origin marker 'web:<email>:<sessionId>' | 'cli:<email>:<host>' — see
    // audit-event.schema.json `actorTag`. Queryable with a trailing wildcard
    // ('cli:*') via AuditQueryPort.
    actorTag  String?
    ipAddress String?
    userAgent String?

    createdAt DateTime @default(now())

    // Relations — the consumer must define `Tenant` and `User` and
    // enable relations. Userless system actions leave userId null.
    // tenant Tenant? @relation(fields: [tenantId], references: [id])
    // user   User?   @relation("AuditLogUser", fields: [userId], references: [id])

    @@index([tenantId, entity, entityId])
    @@index([tenantId, createdAt])
    @@index([entity, action, createdAt])
    @@index([actorTag, createdAt])
    @@map("audit_logs")
}

// =============================================================================
// SaaS-Platform Prisma fragment: catalog entries (discovery review + marketing)
// =============================================================================
//
// REFERENCE SNIPPET — see 03-plan-versions.prisma for conventions.
//
// Three tables:
//   - CapabilityCatalogEntry  — SuperAdmin review status per code-declared
//                               capability (discovery projection)
//   - FeatureCatalogEntry     — ditto for features + marketing fields
//   - MarketingProjection     — marketing texts/pricing/highlights per
//                               plan/bundle version (locale pivot)
//
// Approval lifecycle (#20, feature-/quota-centric):
//   pending → approved (↔ revoke) · outdated (drift) · obsolete
// Approval happens per FEATURE/QUOTA — capabilities now only carry the
// read-only code status (active | experimental | deprecated | retired).
//
// Backfill when migrating from the old vocabulary (per consumer DB):
//   feature_/quota_catalog_entries.discoveryStatus:
//     discovered→pending · accepted→approved · active→approved ·
//     ignored→pending · deprecated→outdated · retired→obsolete
//   capability_catalog_entries: rename column discoveryStatus → codeStatus,
//     values: deprecated→deprecated · retired→retired · everything else→active
//
// Global catalog tables (no tenantId, no RLS). Write access only via the
// SUPER_ADMIN guard in the AdminController.

// -----------------------------------------------------------------------------
// CapabilityCatalogEntry — read-only code fact per code capability (#20).
//
// Every capability declared via @ImplementsCapability(...) appears here after
// the first discovery scan with its decorator status (`codeStatus`). The sync
// always overwrites the code status; it sets `retired` when the capability is
// missing from the new snapshot. There is no longer a business approval at the
// capability level — that lives on the feature/quota.
//
// `featureKey` and `bundleKey` are the aggregation wrappers declared in the
// decorator — denormalized for fast lookup in the discovery UI; the binding
// source, however, remains the code annotation, not this DB entry.
// -----------------------------------------------------------------------------

model CapabilityCatalogEntry {
    id            String  @id @default(uuid())
    projectKey    String // e.g. 'clubapp' | 'demoapp' | …
    capabilityKey String // 'invoice.create' | 'member.archive' | …
    label         String
    description   String?

    // Aggregation wrappers from the decorator (denormalized).
    featureKey String?
    bundleKey  String?

    // Read-only code status from the decorator (#20); 'retired' = removed from code.
    codeStatus String @default("active") // active | experimental | deprecated | retired

    // Code owner tag for audit (e.g. 'accounting', 'membership').
    owner String?

    // Implementation kind (matches decorator.kind):
    // 'endpoint' | 'service' | 'job' | 'event'
    kind String

    // When deprecated: target version + planned removal.
    replacementKey   String?
    deprecatedAt     DateTime?
    removalPlannedAt DateTime?
    reason           String?

    // Locale translations: { "en": { label, description }, "tr": {…} }.
    // The default locale is deliberately absent — fallback in the UI. SPEC_V2 §6.3.
    i18n Json @default("{}")

    sortOrder Int @default(0)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([projectKey, capabilityKey])
    @@index([projectKey, codeStatus])
    @@index([projectKey, featureKey])
    @@map("capability_catalog_entries")
}

// -----------------------------------------------------------------------------
// FeatureCatalogEntry — SuperAdmin review status + marketing master data per
// feature. Aggregation from the capabilities that declare `feature: 'XYZ'`
// in the decorator.
//
// Marketing texts (`marketingLabel` / `marketingDescription`) are the short
// slot for the sidebar/comparison matrix; the *long* locale-specific texts
// live in MarketingProjection (separate table, locale pivot).
//
// `plannedOnly = true` lets the SuperAdmin add a feature that does not yet
// exist in code to a plan (e.g. for roadmap marketing). The blocking strict-
// mode check (SPEC_V2 §8.1) rejects `plannedOnly` features at plan publish —
// they may only appear in internal drafts or warn-only builds.
// -----------------------------------------------------------------------------

model FeatureCatalogEntry {
    id          String  @id @default(uuid())
    projectKey  String
    featureKey  String // 'INVOICE_MANAGEMENT' | 'MEMBER_LIST' | …
    label       String
    description String?

    // Marketing short form (for sidebar/comparison). Detailed texts
    // per locale → MarketingProjection.
    marketingLabel       String?
    marketingDescription String?
    icon                 String?

    // Tier hint for comparison-matrix sorting.
    // Convention: 'CORE' < 'ADVANCED' < 'PRO' < 'ENTERPRISE'
    tier String?

    // True = base feature, always included (not bookable per plan).
    core Boolean @default(false)

    // Code-discovered feature dependencies (#35) and succession (#39) —
    // see FeatureCatalogEntryRow in @saasicat/types.
    requires     String[]
    replaces     String[]
    successorKey String?

    // Approval lifecycle (#20): pending | approved | outdated | obsolete.
    discoveryStatus String @default("pending")

    // Approval signature (#20): freezes the capability set at approval time
    // ('capabilityKey@codeStatus', sorted, '|'-separated). The auto-sync
    // compares against the current snapshot → on drift approved → outdated.
    approvedAt        DateTime?
    approvedBy        String?
    approvedSignature String?

    // True = feature is planned in the SuperAdmin but not yet implemented in
    // code. Blocking strict mode rejects plan publish with plannedOnly
    // features.
    plannedOnly Boolean @default(false)

    // Locale translations { "en": { label, description }, … }. SPEC_V2 §6.3.
    i18n Json @default("{}")

    sortOrder Int @default(0)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([projectKey, featureKey])
    @@index([projectKey, discoveryStatus])
    @@index([projectKey, plannedOnly])
    @@map("feature_catalog_entries")
}

// -----------------------------------------------------------------------------
// QuotaCatalogEntry — SuperAdmin review status per code-declared quota
// (`@DefinesQuota`). `usageProvider` is the class that provides the quota;
// `null` = referenced (`@EnforceQuota`) but provided by no class. A hard quota
// without `usageProvider` is not deployable — `yada app preflight` blocks it
// (SPEC_V2 §6.3 + §8.3).
// -----------------------------------------------------------------------------

model QuotaCatalogEntry {
    id          String  @id @default(uuid())
    projectKey  String
    quotaKey    String // 'invoicesPerMonth' | 'members' | 'storageGb' | …
    label       String
    description String?

    unit       String // Display unit: 'members' | 'GB' | '/month' | …
    featureKey String? // Aggregation wrapper from the decorator (denormalized)

    // Class that declares the quota via @DefinesQuota (= UsageProvider).
    usageProvider   String?
    enforcementMode String  @default("soft") // hard | soft

    // Approval lifecycle (#20): pending | approved | outdated | obsolete.
    discoveryStatus String @default("pending")

    // Predecessor quotaKeys this quota replaces + a successor pointer (#39),
    // analogous to FeatureCatalogEntry. The discovery sync overwrites both.
    replaces     String[]
    successorKey String?

    // Approval signature (#20): code-derived quota facts at approval time
    // ('unit|enforcementMode|usageProvider|featureKey'); on drift approved →
    // outdated.
    approvedAt        DateTime?
    approvedBy        String?
    approvedSignature String?

    // Locale translations { "en": { label, unit, description }, … }.
    i18n Json @default("{}")

    sortOrder Int @default(0)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([projectKey, quotaKey])
    @@index([projectKey, discoveryStatus])
    @@map("quota_catalog_entries")
}

// -----------------------------------------------------------------------------
// MarketingProjection — locale-specific marketing texts per
// plan/bundle version.
//
// Read and projected by the public catalog controller
// (`GET /public/catalog?locale=de`). Only versions with status `marketed` and
// a matching MarketingProjection entry appear in the public list.
//
// Polymorphic reference via (`targetType`, `targetVersionId`) instead of three
// separate FK columns — deliberate, because a cascade delete for three models
// would be complicated and uniqueness via (targetType, targetVersionId,
// locale) is sufficient. App logic checks existence on read.
//
// MVP: locale `de` is mandatory; further locales (e.g. `en`) are allowed as
// schema preparation but not enforced (see SPEC_V2 V2-Q1).
// -----------------------------------------------------------------------------

model MarketingProjection {
    id         String @id @default(uuid())
    projectKey String

    // Polymorphic reference to a versioned entity.
    targetType      String // 'PLAN' | 'BUNDLE'
    targetVersionId String // PlanVersion.id | BundleVersion.id

    locale String @default("de") // ISO-639-1, optionally with a region suffix ('de', 'en', 'de-AT')

    displayLabel String
    description  String

    // Visibility in the public catalog — false = projection exists but does
    // not appear on the pricing page.
    visible Boolean @default(true)

    // Optional badge at the top of the card ('Beliebt', 'Neu'). '' = no badge.
    badge String @default("")

    // Top features for the public catalog card: [{ label, strong }].
    // Order is the display order.
    topFeatures Json @default("[]") // { label: string; strong: string }[]

    // Free trial period — controls the auto-generated CTA text.
    trialEnabled Boolean @default(false)
    trialDays    Int     @default(30)

    // Optional formatted pricing tag (e.g. "€ 9,90 / Monat" or "auf Anfrage").
    // If null: pricing is formatted automatically from PlanVersion.monthlyNet
    // etc. at public-catalog render time.
    priceTag String?

    // Overrides the auto-generated call-to-action text.
    ctaLabel String?

    // Sort order in the public list (DESC). Higher values first.
    priority Int @default(0)

    // "Empfohlen" star / featured highlight in the UI.
    highlight Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([targetType, targetVersionId, locale])
    @@index([projectKey, targetType, locale, priority])
    @@map("marketing_projections")
}

// -----------------------------------------------------------------------------
// MarketingSettings — project-wide, runtime-editable marketing config.
// One row per project (`projectKey` unique). Currently exactly one field:
// `activeLocales` — the subset of the `availableLocales` pool activated in the
// marketing catalog (the pool comes from the app config, SPEC_V2 §6.5).
// If the row is missing, the full pool counts as active.
// -----------------------------------------------------------------------------

model MarketingSettings {
    id         String @id @default(uuid())
    projectKey String @unique

    activeLocales Json @default("[]") // string[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("marketing_settings")
}

// =============================================================================
// SaaS-Platform Prisma fragment: SuperAdmin identity + MFA
// =============================================================================
//
// REFERENCE SNIPPET — see 01-subscription.prisma for conventions.
//
// Platform-owned SuperAdmin accounts, separate from the consumer's tenant
// user model. The `@saasicat/adapter-prisma` adapters
// (`PrismaSuperAdminBootstrapAdapter`, `PrismaMfaAdapter`) write into these
// tables; the consumer's admin auth reads them for SuperAdmin login.
//
// Apps that keep SuperAdmins inside their own user table skip this fragment
// and implement `SuperAdminProvisioningPort` / `MfaPort` themselves.
//
// Global tables (no tenantId, no RLS).

model SuperAdminUser {
    id           String  @id @default(uuid())
    email        String  @unique // stored lowercase; adapters normalize
    passwordHash String
    firstName    String?
    lastName     String?

    // Constant today ('SUPER_ADMIN'); column exists so later platform roles
    // do not need a migration.
    platformRole String  @default("SUPER_ADMIN")
    isActive     Boolean @default(true)

    lastLoginAt DateTime?
    deletedAt   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isActive, deletedAt])
    @@map("super_admin_users")
}

model SuperAdminMfa {
    // Admin user ID — deliberately NO hard FK: `MfaPort` also serves apps
    // that keep their admin identities in their own user table. Apps whose
    // admins live exclusively in `super_admin_users` may add the relation:
    // user SuperAdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String    @id
    secret    String? // TOTP secret; null after reset
    enabledAt DateTime? // set when a secret is stored, null after reset

    updatedAt DateTime @updatedAt

    @@map("super_admin_mfa")
}

// =============================================================================
// SaaS-Platform Prisma fragment: Subscription + Payment method
// =============================================================================
//
// REFERENCE SNIPPET — not a standalone schema. Consumers copy
// models into their `schema.prisma` and adapt the FK relations to their own
// `Tenant`/`User` models.
//
// Conventions:
//   - Plan/feature keys as `String` — source of truth is the
//     consumer's `config/plans.yaml`, validated via
//     `@saasicat/spec/schemas/plan-catalog.schema.json`.
//     Whoever prefers Postgres enums can declare an enum locally and
//     cast the field via `@db.<EnumName>` — not a platform requirement.
//   - FK columns to consumer models are declared as `String` with a
//     commented-out example relation. The consumer adds the `@relation`
//     with their own `Tenant`/`User` model.
//   - `@@map` names are the canonical table names — please do not
//     change them, otherwise the shared migration path breaks in P1.5+.
//
// Accompanying fragments:
//   - 03-plan-versions.prisma  (PlanVersion — referenced here)
//   - 02-promo-code.prisma     (PromoCodeRedemption has 1:1 to Subscription)

// -----------------------------------------------------------------------------
// Universal enums — project-independent, identical in every consumer.
// -----------------------------------------------------------------------------

enum BillingCycle {
    MONTHLY
    YEARLY
}

enum SubscriptionStatus {
    TRIAL
    ACTIVE
    PAST_DUE
    CANCELED
    PENDING_SALES
}

enum SubscriptionPaymentType {
    CARD
    SEPA
    PAYPAL
    KLARNA
    INVOICE
}

// -----------------------------------------------------------------------------
// Subscription — one per Tenant. Binds to PlanVersion (see 03-plan-versions).
// -----------------------------------------------------------------------------

model Subscription {
    id       String @id @default(uuid())
    tenantId String @unique
    // Plan key from plans.yaml (`plans[].id`). Whoever wants an enum: declare locally.
    plan         String
    billingCycle BillingCycle       @default(YEARLY)
    status       SubscriptionStatus @default(TRIAL)

    trialEndsAt DateTime?
    startedAt   DateTime?
    canceledAt  DateTime?

    // Renewal period (maintained by PlanVersionRenewalService).
    currentPeriodStart DateTime?
    currentPeriodEnd   DateTime?

    // Plan versioning — binds to a published PlanVersion.
    // `pendingPlanVersion*` concern a version change within the
    // same plan; `pendingPlan` the change to a different plan. Both
    // can coexist.
    //
    // Every subscription binds a concrete published PlanVersion.
    planVersionId                      String
    pendingPlanVersionId               String?
    pendingPlanVersionEffectiveAt      DateTime?
    pendingPlanVersionAccepted         Boolean   @default(false)
    pendingPlanVersionAcceptedAt       DateTime?
    pendingPlanVersionAcceptedByUserId String?
    pendingPlanVersionNotifiedAt       DateTime?
    pendingPlanVersionReminderSentAt   DateTime?

    // Trial / scheduled plan changes
    trialEntitlementPlan String? // Default entitlement during TRIAL
    postTrialPlan        String? // Target package after trial
    pendingPlan          String? // Downgrade/change at period end
    pendingBillingCycle  BillingCycle?
    pendingEffectiveAt   DateTime?

    // Special contract / pilot — audit (who/when) lives in the AuditLog.
    customMonthlyNet Decimal?  @db.Decimal(10, 2)
    customLimits     Json? // { maxUsers?, maxVehicles?, maxStorageGb?, features?: string[] }
    customNote       String?
    isPilot          Boolean   @default(false)
    pilotEndsAt      DateTime?
    pilotNote        String?

    // Package consistency (METAMODELL §17a) — references the CheckoutOffer
    // from which the Subscription originated; `packageSnapshot` is the offer
    // frozen at closing time (plan + promo + bundles +
    // quotas + price breakdown). Price-fixed billing
    // basis; null for legacy/direct subscriptions without an onboarding offer.
    checkoutOfferId String?
    packageSnapshot Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations.
    tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    paymentMethod       SubscriptionPaymentMethod?
    promoRedemption     PromoCodeRedemption? // see 02-promo-code.prisma
    planVersion         PlanVersion                 @relation("SubscriptionPlanVersion", fields: [planVersionId], references: [id])
    pendingPlanVersion  PlanVersion?                @relation("SubscriptionPendingPlanVersion", fields: [pendingPlanVersionId], references: [id])
    // Standalone add-on bookings (see the SubscriptionBundle model below).
    bundles             SubscriptionBundle[]

    @@index([tenantId])
    @@index([planVersionId])
    @@index([pendingPlanVersionId])
    @@index([currentPeriodEnd])
    @@map("subscriptions")
}

// -----------------------------------------------------------------------------
// SubscriptionPaymentMethod — masked payment data per Subscription.
// -----------------------------------------------------------------------------

model SubscriptionPaymentMethod {
    id             String                  @id @default(uuid())
    subscriptionId String                  @unique
    type           SubscriptionPaymentType

    // Card (masked)
    cardName  String?
    cardBrand String?
    cardLast4 String?
    cardExp   String?

    // SEPA (masked)
    ibanLast4 String?
    ibanName  String?

    // PayPal
    paypalEmail String?

    // Klarna
    klarnaPlan String? // "invoice" | "instalments"

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

    @@map("subscription_payment_methods")
}

// -----------------------------------------------------------------------------
// CheckoutOffer — immutable package snapshot from the website through to the
// Subscription (METAMODELL §17a).
//
// On a package click on the pricing page, `POST /public/checkout-offer` creates
// an offer; its `id` travels as `?offer=<id>` into onboarding. There
// the tenant customizes it (bundles/quotas) — `PATCH` writes
// the delta back. On subscription creation the offer becomes `consumed` and
// is frozen as `Subscription.packageSnapshot`.
//
// Global table (no RLS) — the offer is created before the tenant is created.
// -----------------------------------------------------------------------------

model CheckoutOffer {
    id         String @id @default(uuid())
    projectKey String

    planKey       String
    planVersionId String?
    billingCycle  String // monthly | yearly

    promotionId String?
    promoCode   String?

    bundles Json @default("[]") // string[]
    bundleVersionIds Json @default("[]") // concrete BundleVersion IDs (V3)

    priceBreakdown     Json
    lineItems          Json @default("[]") // ContractLineItem snapshot shape before contract conclusion
    promotionSnapshots Json @default("[]")
    promoCodeSnapshot  Json?
    locale             String @default("de")
    validUntil         DateTime?

    status     String    @default("open") // open | consumed | expired
    consumedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([projectKey, status])
    @@map("checkout_offers")
}

// =============================================================================
// SaaS-Platform Prisma fragment: promo codes
// =============================================================================
//
// REFERENCE SNIPPET — see 01-subscription.prisma for conventions.
//
// Accompanying fragments:
//   - 01-subscription.prisma  (PromoCodeRedemption is 1:1 with Subscription)

// -----------------------------------------------------------------------------
// Universal enums.
// -----------------------------------------------------------------------------

enum PromoCodeValueType {
    PERCENT
    ABSOLUTE
}

enum PromoCodeDurationType {
    ONCE
    MONTHS
    BILLING_CYCLES
}

enum PromoCodeStatus {
    ACTIVE
    PAUSED
    EXHAUSTED
    EXPIRED
}

enum PromoCodeRedemptionStatus {
    ACTIVE
    REVERSED
    EXPIRED
}

// -----------------------------------------------------------------------------
// PromoCode — marketing discount code for onboarding checkout.
// -----------------------------------------------------------------------------

model PromoCode {
    id        String             @id @default(uuid())
    code      String             @unique // case-insensitive, stored in UPPER
    valueType PromoCodeValueType
    value     Decimal            @db.Decimal(8, 2) // % for PERCENT, EUR for ABSOLUTE

    // Duration
    durationType  PromoCodeDurationType @default(ONCE)
    durationValue Int? // null for ONCE; 1–24 for MONTHS / BILLING_CYCLES

    validFrom      DateTime?
    validUntil     DateTime?
    maxRedemptions Int? // null = unlimited

    // Availability-relevant — counts only redemptions with status=ACTIVE.
    // Incremented atomically in the redeem() path, decremented on trial cancellation.
    redemptionsCount Int @default(0)

    // Plan whitelist as String[] — values are plan IDs from plans.yaml.
    // Consumers using a Postgres enum can cast the field locally.
    appliesToPlans   String[] // empty = all plans; otherwise whitelist
    appliesToBilling BillingCycle? // null = both; otherwise only MONTHLY or YEARLY

    // Anti-abuse
    firstTimeCustomersOnly Boolean  @default(true)
    minimumPlanAmountGross Decimal? @db.Decimal(10, 2)
    allowZeroInvoice       Boolean  @default(false)

    status      PromoCodeStatus @default(ACTIVE)
    description String?
    campaignTag String?

    // Accounting — SKR account no. (e.g. "4736"); if null, the
    // consumer falls back to the system default (configurable in the consumer).
    revenueDeductionAccount String?

    createdById String // SUPER_ADMIN user ID (consumer FK, see header)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime? // soft delete; never hard-delete for audit reasons

    redemptions    PromoCodeRedemption[]
    validationLogs PromoCodeValidationLog[]

    @@index([status, validFrom, validUntil])
    @@index([campaignTag])
    @@map("promo_codes")
}

// -----------------------------------------------------------------------------
// PromoCodeRedemption — a subscription can have only one active code.
// -----------------------------------------------------------------------------

model PromoCodeRedemption {
    id             String @id @default(uuid())
    promoCodeId    String
    subscriptionId String @unique
    tenantId       String

    // Snapshot of the code rule at redemption time.
    appliedValueType     PromoCodeValueType
    appliedValue         Decimal               @db.Decimal(8, 2)
    appliedDurationType  PromoCodeDurationType
    appliedDurationValue Int?

    // Validity window — endsAt null for ONCE, otherwise computed from the snapshot.
    startsAt DateTime
    endsAt   DateTime?

    status     PromoCodeRedemptionStatus @default(ACTIVE)
    redeemedAt DateTime                  @default(now())
    reversedAt DateTime?

    promoCode    PromoCode    @relation(fields: [promoCodeId], references: [id])
    subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
    tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

    @@index([tenantId])
    @@index([promoCodeId, status])
    @@index([startsAt, endsAt])
    @@map("promo_code_redemptions")
}

// -----------------------------------------------------------------------------
// PromoCodeValidationLog — audit trail of all validation attempts
// (including failed NOT_FOUND/EXPIRED), for anti-abuse analysis.
// -----------------------------------------------------------------------------

model PromoCodeValidationLog {
    id          String   @id @default(uuid())
    promoCodeId String? // null for NOT_FOUND attempts
    codeAttempt String // input in UPPER (retained even for NOT_FOUND)
    ipHash      String? // hash of the IP, no plaintext (data protection)
    sessionId   String? // onboarding session / CSRF token
    result      String // "VALID" | "EXPIRED" | "EXHAUSTED" | "NOT_FOUND" | "PLAN_MISMATCH" | …
    createdAt   DateTime @default(now())

    promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

    @@index([codeAttempt, createdAt])
    @@index([ipHash, createdAt])
    @@index([sessionId, createdAt])
    @@map("promo_code_validation_logs")
}

// =============================================================================
// SaaS platform Prisma fragment: plan versioning
// =============================================================================
//
// REFERENCE SNIPPET — see 01-subscription.prisma for conventions.
//
// Global catalog tables (no tenantId, no RLS). Write access only via the
// SUPER_ADMIN guard in the AdminController of the `@saasicat/nest`
// package.
//
// Per identity key (planId):
//   - at most 1 draft (publishedAt IS NULL) — constraint via a partial unique
//     index in the migration (the Prisma schema cannot express partial unique:
//     add it in the SQL migration as
//     `CREATE UNIQUE INDEX … WHERE published_at IS NULL`).
//   - multiple published versions, monotonically incrementing `version`.
//   - `supersededAt` marks "no longer actively marketed"; the version
//     remains billing-valid for existing subscriptions (contractual plan guarantee).

// -----------------------------------------------------------------------------
// Plan — root identity of a plan (SPEC_V2 §11.1 M6).
// `planKey` is the business plan identity (STARTER / STANDARD / PROFESSIONAL),
// unique per `projectKey`. PlanVersion.planId points **softly** to
// `Plan.planKey` (no DB FK — the binding is enforced via service logic in M6
// so that the greenfield cutover can run without a destructive schema
// migration).
//
// Soft-delete via `deletedAt`. A deleted plan root hides its
// PlanVersions in the UI, but keeps them effective for existing subscriptions
// (contract protection P1) — analogous to Bundle.
// -----------------------------------------------------------------------------

model Plan {
    id          String  @id @default(uuid())
    projectKey  String
    planKey     String
    label       String
    description String?
    icon        String?
    sortOrder   Int     @default(0)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([projectKey, planKey])
    @@index([projectKey, deletedAt])
    @@map("plans")
}

// -----------------------------------------------------------------------------
// PlanVersion — exactly one lineage per `planId` (= plan key from plans.yaml).
// -----------------------------------------------------------------------------

model PlanVersion {
    id            String  @id @default(uuid())
    planId        String // plan key from plans.yaml (`plans[].id`)
    version       Int
    baseVersionId String? // predecessor the draft diffs against (nullable for v1)

    // Snapshot of the plan definition at the time of publishing.
    // `features` is the published feature set as FeatureKey[].
    // `quotas` is a free-form JSON object; concrete quota keys come from
    // plans.yaml (`quotaKeys` pattern). Example:
    //   { "users": 5, "vehicles": 100, "storageGb": 50 }
    features Json
    quotas   Json

    monthlyNet Decimal @db.Decimal(10, 2)
    yearlyNet  Decimal @db.Decimal(10, 2) // net total amount per year for the YEARLY cycle
    marketed   Boolean @default(true)

    publishedAt      DateTime?
    supersededAt     DateTime?
    publishedChanges Json? // VersionChange[] — see @saasicat/types
    changeNote       String
    nonRegressive    Boolean @default(true)

    createdByUserId   String?
    publishedByUserId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    baseVersion          PlanVersion?   @relation("PlanVersionLineage", fields: [baseVersionId], references: [id])
    derivedVersions      PlanVersion[]  @relation("PlanVersionLineage")
    subscriptionsCurrent Subscription[] @relation("SubscriptionPlanVersion")
    subscriptionsPending Subscription[] @relation("SubscriptionPendingPlanVersion")

    @@unique([planId, version])
    @@index([planId, supersededAt])
    @@index([planId, publishedAt])
    @@map("plan_versions")
}

// =============================================================================
// SaaS platform Prisma fragment: Bundle (plan catalog extension)
// =============================================================================
//
// REFERENCE SNIPPET — see 03-plan-versions.prisma for versioning conventions.
//
// Global catalog tables (no tenantId, no RLS). Write access only via the
// SUPER_ADMIN guard in the AdminController of the `@saasicat/nest`
// package. Entries are assigned to the respective consumer app via
// `projectKey`.
//
// Versioning pattern identical to PlanVersion:
//   - at most 1 draft (publishedAt IS NULL) per identity — constraint via a
//     partial unique index in the migration.
//   - multiple published versions, monotonically incremental `version`.
//   - `supersededAt` marks "no longer actively marketed"; existing bookings
//     stay on the committed version (contractual plan guarantee P1).
//
// -----------------------------------------------------------------------------
// Bundle — reusable component of features + quotas + pricing.
//
// Root entity without content — the purchasable fields (features, quotas,
// pricing) live on BundleVersion.
// -----------------------------------------------------------------------------

model Bundle {
    id          String   @id @default(uuid())
    projectKey  String // e.g. 'clubapp' | 'demoapp' | …
    bundleKey   String // SCREAMING_SNAKE_CASE, e.g. 'SPORT', 'ACCOUNTING', 'EVERSEND_PEPPOL'
    label       String
    description String?
    icon        String?
    sortOrder   Int      @default(0)

    // Locale translations { "en": { label, description }, … }. SPEC_V2 §6.4.
    i18n Json @default("{}")

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    versions BundleVersion[]

    @@unique([projectKey, bundleKey])
    @@index([projectKey, deletedAt])
    @@map("bundles")
}

// -----------------------------------------------------------------------------
// BundleVersion — versioned composition (features, quotas, pricing).
// `features` is FeatureKey[] (references Discovery / FeatureCatalogEntry).
// `quotas` is Record<QuotaKey, number>; -1 = unlimited; missing key = 0.
// `compatibility` is BundleCompatibility (`planIds?` whitelist). Empty =
// usable with every plan. `pricingOverrides` is an array of
// BundlePricingOverride values for plan-dependent prices.
// -----------------------------------------------------------------------------

model BundleVersion {
    id            String  @id @default(uuid())
    bundleId      String
    version       Int
    baseVersionId String? // predecessor; null for v1

    features         Json // FeatureKey[]
    quotas           Json @default("{}") // Record<QuotaKey, number>
    compatibility    Json @default("{}") // BundleCompatibility
    pricingOverrides Json @default("[]") // BundlePricingOverride[]

    monthlyNet Decimal? @db.Decimal(10, 2) // default price; null = only via override
    yearlyNet  Decimal? @db.Decimal(10, 2)
    marketed   Boolean  @default(true)

    publishedAt      DateTime?
    supersededAt     DateTime?
    publishedChanges Json? // VersionChange[] — diff to predecessor version
    changeNote       String  @default("")
    nonRegressive    Boolean @default(true)

    createdByUserId   String?
    publishedByUserId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    bundle              Bundle               @relation(fields: [bundleId], references: [id], onDelete: Cascade)
    baseVersion         BundleVersion?       @relation("BundleVersionLineage", fields: [baseVersionId], references: [id])
    derivedVersions     BundleVersion[]      @relation("BundleVersionLineage")
    // Standalone add-on bookings pinned to this version (see the
    // SubscriptionBundle model below).
    subscriptionBundles SubscriptionBundle[]

    @@unique([bundleId, version])
    @@index([bundleId, supersededAt])
    @@index([bundleId, publishedAt])
    @@map("bundle_versions")
}

// =============================================================================
// SaaS-Platform Prisma fragment: Promotion (time-scheduled pricing campaigns)
// =============================================================================
//
// REFERENCE SNIPPET — see 03-plan-versions.prisma for conventions.
//
// A Promotion is a catalog-side, time-limited pricing campaign.
// It overrides the pricing-page price automatically (without entering a code,
// unless `requiresCoupon`). Separate from `PromoCode` (a redeemable
// checkout voucher, 02-promo-code.prisma) — `requiresCoupon = true`
// couples a Promotion to existing PromoCode codes via `codes`.
//
// Global catalog table (no tenantId, no RLS). Write access only
// via the SUPER_ADMIN guard in the AdminController.

model Promotion {
    id         String @id @default(uuid())
    projectKey String // e.g. 'clubapp' | 'demoapp' | …

    // Internal label (not public).
    internalLabel String

    // Campaign type: percent | amount | intro | freeMonths
    type String

    // Type-dependent value:
    //   percent/amount → number
    //   intro          → { price, months }
    //   freeMonths     → number
    value Json

    // Target type of the keys in `appliesTo`: PLAN | BUNDLE | OFFER.
    // Null/missing in legacy records is interpreted as PLAN.
    targetType String @default("PLAN")

    // Target keys the campaign applies to.
    appliesTo Json @default("[]") // string[]

    // Billing cycle: monthly | yearly | both
    billingCycle String @default("both")

    validFrom DateTime
    validTo   DateTime

    // On overlap, the highest value wins.
    priority Int @default(0)

    // Language restriction; null = all locales.
    onlyLocales Json? // string[] | null

    requiresCoupon Boolean @default(false)
    codes          Json    @default("[]") // string[] — referenced PromoCode codes

    // UI accent color (timeline/ribbon).
    color String @default("#2563eb")

    // Locale texts { "de": { badge, fineprint }, … }.
    i18n Json @default("{}")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([projectKey, targetType, validFrom, validTo])
    @@map("promotions")
}

// =============================================================================
// SaaS platform Prisma fragment: SubscriptionContract + ContractLineItem
// =============================================================================
//
// REFERENCE SNIPPET — not a standalone schema. Consumers copy the models into
// their `schema.prisma` and add FK relations to Tenant/User.
//
// V3 rule: billing and entitlement must not depend on live-mutable catalog
// tables. `SubscriptionContract` and `ContractLineItem` therefore store full
// snapshots. Catalog FKs are optional and only audit/trace references.

enum SubscriptionContractStatus {
    active
    scheduled
    terminated
    superseded
}

enum ContractLineItemKind {
    plan
    bundle
    quota
    feature
    discount
}

model SubscriptionContract {
    id         String @id @default(uuid())
    projectKey String
    tenantId   String

    status         SubscriptionContractStatus @default(active)
    effectiveFrom  DateTime
    effectiveUntil DateTime?

    // Optional trace back to the offer/catalog. The contract stays valid even
    // when these target objects are archived or physically deleted.
    originalOfferId          String?
    originalPlanVersionId    String?
    originalBundleVersionIds Json @default("[]")

    // Full snapshots for runtime, billing, and later display.
    entitlementSnapshot Json?
    priceSnapshot       Json
    promotionSnapshots  Json @default("[]")
    promoCodeSnapshots  Json @default("[]")
    termsSnapshot       Json?

    lineItems ContractLineItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

    @@index([tenantId, status, effectiveFrom])
    @@index([projectKey, status])
    @@index([originalOfferId])
    @@map("subscription_contracts")
}

model ContractLineItem {
    id         String @id @default(uuid())
    contractId String

    kind            ContractLineItemKind
    sourceKey       String
    sourceVersionId String?

    titleSnapshot       String
    descriptionSnapshot String?

    quantity     Int     @default(1)
    unit         String?
    priceNet     Decimal @db.Decimal(10, 2)
    priceGross   Decimal @db.Decimal(10, 2)
    billingCycle String // monthly | yearly

    minimumTermUntil DateTime?

    featuresSnapshot     Json @default("[]")
    quotaEffectsSnapshot Json @default("{}")
    metadata             Json?

    createdAt DateTime @default(now())

    contract SubscriptionContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

    @@index([contractId, kind])
    @@index([sourceVersionId])
    @@map("contract_line_items")
}

// =============================================================================
// SaaS-Platform Prisma fragment: SubscriptionBundle (standalone add-on booking)
// =============================================================================
//
// REFERENCE SNIPPET — see 01-subscription.prisma for conventions.
//
// A SubscriptionBundle is a bundle booked ON TOP of a subscription's plan —
// the tenant "bundle store". It pins a concrete BundleVersion (features/quotas
// frozen at booking), carries its own minimum term and cancellation window,
// and is billed independently of the plan. The reverse relations are enabled
// on Subscription (`bundles`) and BundleVersion (`subscriptionBundles`).

model SubscriptionBundle {
    id              String @id @default(uuid())
    subscriptionId  String
    bundleVersionId String

    startedAt DateTime

    // Minimum contractual term; a cancellation before this date takes effect
    // only at `minimumTermEndsAt`.
    minimumTermEndsAt DateTime?

    // Cancellation: requested at `canceledAt`, effective at
    // `canceledEffectiveAt` (period/term end). Both null = active booking.
    canceledAt          DateTime?
    canceledEffectiveAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // The subscription this add-on is booked on. Restrict the BundleVersion so
    // a booked version cannot be hard-deleted from the catalog.
    subscription  Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
    bundleVersion BundleVersion @relation(fields: [bundleVersionId], references: [id], onDelete: Restrict)

    @@index([subscriptionId])
    @@index([bundleVersionId])
    @@index([canceledEffectiveAt])
    @@map("subscription_bundles")
}
