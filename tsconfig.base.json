{
    "compilerOptions": {
        "target": "ES2023",
        "module": "commonjs",
        "lib": ["ES2023"],
        "strict": true,
        "strictPropertyInitialization": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0"
    }
}
