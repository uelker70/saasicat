{
    "name": "@saasicat/prisma",
    "version": "0.2.0",
    "description": "Default Prisma adapters for the SaaS platform: PrismaMfaAdapter, PrismaAuditAdapter, AsyncLocalRlsBypassAdapter, PrismaPlanCatalogReadSink. Assumes the prisma-fragments schema from @saasicat/spec (table names like SuperAdminMfa, AuditEntry, Plan, CatalogPlanVersion, ...). Apps with a diverging schema write their own adapters — the platform ports stay identical.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean --external @saasicat/types --external @nestjs/common",
        "pretest": "pnpm run build",
        "test": "node --test tests/**/*.test.js"
    },
    "dependencies": {
        "@saasicat/types": "workspace:^"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.0.0"
    },
    "devDependencies": {
        "@nestjs/common": "^11.0.0",
        "@types/node": "^25.6.0",
        "tsup": "^8.0.0",
        "typescript": "^6.0.0"
    },
    "license": "Apache-2.0",
    "author": "Taci Uelker",
    "homepage": "https://github.com/uelker70/saasicat",
    "repository": {
        "type": "git",
        "url": "https://github.com/uelker70/saasicat.git",
        "directory": "packages/saas-platform-prisma"
    },
    "bugs": {
        "url": "https://github.com/uelker70/saasicat/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
