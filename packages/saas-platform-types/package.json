{
    "name": "@saasicat/types",
    "version": "0.7.0",
    "description": "TypeScript interfaces of the SaaS platform: AdminManifest, PlanCatalog, PromoCode, AuditEvent, adapter ports. Derived from the JSON Schemas in @saasicat/spec.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "gen:types": "node scripts/gen-types-from-schemas.mjs",
        "pretest": "pnpm run build",
        "test": "node --test 'tests/*.test.js'"
    },
    "devDependencies": {
        "json-schema-to-typescript": "^15.0.4",
        "tsup": "^8.0.0",
        "typescript": "^6.0.0"
    },
    "license": "Apache-2.0",
    "author": "Taci Uelker",
    "homepage": "https://github.com/uelker70/saasicat",
    "repository": {
        "type": "git",
        "url": "https://github.com/uelker70/saasicat.git",
        "directory": "packages/saas-platform-types"
    },
    "bugs": {
        "url": "https://github.com/uelker70/saasicat/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
