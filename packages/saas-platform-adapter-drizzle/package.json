{
    "name": "@saasicat/adapter-drizzle",
    "version": "0.6.0",
    "description": "Drizzle + PostgreSQL persistence adapter for SaaSicat: drizzlePersistence() bundle plus the individual adapters (MFA, audit, RLS bypass, transaction runner, subscription/plan-version/promo repositories, SuperAdmin bootstrap, plan-catalog sinks). Targets the canonical schema from @saasicat/spec and passes the same executable persistence contract as @saasicat/adapter-prisma.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "pretest": "pnpm run build",
        "test": "node --test tests/**/*.test.js",
        "test:integration": "node --test tests-integration/**/*.test.js"
    },
    "dependencies": {
        "@saasicat/types": "workspace:^"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.0.0",
        "drizzle-orm": ">=0.40.0 <1.0.0"
    },
    "devDependencies": {
        "@nestjs/common": "^11.0.0",
        "@saasicat/persistence-testing": "workspace:^",
        "@saasicat/spec": "workspace:^",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.15.0",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.22.0",
        "tsup": "^8.0.0",
        "typescript": "^6.0.0"
    },
    "license": "Apache-2.0",
    "author": "Taci Uelker",
    "homepage": "https://github.com/uelker70/saasicat",
    "repository": {
        "type": "git",
        "url": "https://github.com/uelker70/saasicat.git",
        "directory": "packages/saas-platform-adapter-drizzle"
    },
    "bugs": {
        "url": "https://github.com/uelker70/saasicat/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
